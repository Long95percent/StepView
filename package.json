{
    "name": "stepview",
    "version": "1.0.0",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite --host 0.0.0.0",
        "build": "vite build --base ./",
        "preview": "vite preview --host 0.0.0.0",
        "test": "vitest run --pool=threads",
        "desktop": "npm-run-all -p dev electron:wait",
        "electron:wait": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.js",
        "desktop:prod": "npm run build && electron electron/main.js",
        "dist:win": "npm run build && electron-builder --win dir"
    },
    "build": {
        "appId": "com.stepview.app",
        "productName": "StepView",
        "directories": {
            "output": "release"
        },
        "electronDist": "node_modules/electron/dist",
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "win": {
            "signAndEditExecutable": false,
            "target": [
                "dir"
            ]
        }
    },
    "dependencies": {
        "@vitejs/plugin-react": "latest",
        "cross-env": "latest",
        "npm-run-all": "latest",
        "react": "latest",
        "react-dom": "latest",
        "vite": "latest",
        "vitest": "latest",
        "wait-on": "latest"
    },
    "devDependencies": {
        "electron": "^42.1.0",
        "electron-builder": "^26.8.1"
    }
}
